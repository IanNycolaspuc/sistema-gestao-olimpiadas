@startuml
skinparam componentStyle rectangle
skinparam shadowing false
skinparam component {
  BackgroundColor #F8FBFF
  BorderColor #2E5EAA
}

title Sistema de Gestao das Olimpiadas - Diagrama de Componentes

actor "Usuario" as User

component "Interface Web" as WebUI
component "API do SGO" as API
component "Modulo de\nCompeticoes" as Comp
component "Modulo de\nInscricoes" as Inscr
component "Modulo de\nAlocacao" as Aloc
component "Modulo de\nResultados" as Result
component "Modulo de\nRelatorios" as Rel
component "Modulo de\nAutenticacao" as Auth
component "Repositorio de Dados" as Repo

database "Banco de Dados\nSGO" as DB
cloud "Servico de\nExportacao PDF/CSV" as Export

User --> WebUI : usa pelo navegador
WebUI --> API : requisicoes HTTPS/JSON
API --> Auth : autentica usuarios
API --> Comp : cadastrar e consultar competicoes
API --> Inscr : inscrever atletas
API --> Aloc : alocar locais
API --> Result : registrar podio
API --> Rel : gerar quadro de medalhas

Comp --> Repo
Inscr --> Repo
Aloc --> Repo
Result --> Repo
Rel --> Repo
Repo --> DB : SQL
Rel --> Export : exporta relatorios

Inscr ..> Comp : consulta competicao
Aloc ..> Comp : atualiza local da competicao
Result ..> Comp : finaliza competicao
Rel ..> Result : consolida medalhas
@enduml
