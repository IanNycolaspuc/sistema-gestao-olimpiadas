@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F8FBFF
  BorderColor #2E5EAA
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #444444
}

title Sistema de Gestao das Olimpiadas - Diagrama de Caso de Uso

actor "Administrador\ndo Sistema" as Admin
actor "Gestor de\nCompeticoes" as Gestor
actor "Comite Olimpico\n/ Delegacao" as Comite
actor "Operador de\nResultados" as Operador
actor "Publico /\nImprensa" as Publico

rectangle "SGO - Sistema de Gestao das Olimpiadas" {
  usecase "Autenticar usuario" as UC00
  usecase "Cadastrar competicao" as UC01
  usecase "Atualizar dados\nda competicao" as UC02
  usecase "Consultar competicoes" as UC03
  usecase "Inscrever atleta" as UC04
  usecase "Validar pais do atleta\npor modalidade" as UC05
  usecase "Alocar local" as UC06
  usecase "Verificar conflito\nde horario/local" as UC07
  usecase "Registrar resultados" as UC08
  usecase "Definir ouro, prata\ne bronze" as UC09
  usecase "Gerar relatorio\nde medalhas" as UC10
  usecase "Consultar quadro\nde medalhas" as UC11
  usecase "Gerenciar cadastros\nbasicos" as UC12
}

Admin --> UC00
Admin --> UC12
Admin --> UC01
Admin --> UC06
Admin --> UC10

Gestor --> UC00
Gestor --> UC01
Gestor --> UC02
Gestor --> UC03
Gestor --> UC06

Comite --> UC00
Comite --> UC03
Comite --> UC04

Operador --> UC00
Operador --> UC03
Operador --> UC08

Publico --> UC03
Publico --> UC11

UC04 ..> UC05 : <<include>>
UC06 ..> UC07 : <<include>>
UC08 ..> UC09 : <<include>>
UC10 ..> UC11 : <<include>>
UC01 ..> UC06 : <<extend>>
UC02 ..> UC07 : <<include>>
@enduml
